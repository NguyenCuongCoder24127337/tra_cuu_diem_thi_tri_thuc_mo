<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { title: "Bang diem" }) %>
  <body>
    <%- include("partials/header", { user: student }) %>

    <main class="container dashboard-wrap">
      <section class="profile card">
        <h1>Thong tin hoc sinh</h1>
        <div class="profile-grid">
          <p><strong>Ho va ten:</strong> <%= student.fullName %></p>
          <p><strong>Lop:</strong> <%= student.className %></p>
          <p><strong>Ngay sinh:</strong> <%= student.dob || "Chua cap nhat" %></p>
          <p><strong>Username:</strong> <%= student.username %></p>
        </div>
      </section>

      <section class="scores card">
        <h2>Diem tung mon</h2>
        <table>
          <thead>
            <tr>
              <th>Mon hoc</th>
              <th>Diem</th>
            </tr>
          </thead>
          <tbody>
            <% for (const subject of subjects) { %>
            <tr>
              <td><%= subjectLabels[subject] %></td>
              <td><%= Number(scores[subject] || 0).toFixed(2) %></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </section>

      <section class="leaderboard card">
        <h2>Top 3 diem cao nhat theo tung mon</h2>
        <div class="leader-grid">
          <% for (const subject of subjects) { %>
          <article class="leader-item">
            <h3><%= subjectLabels[subject] %></h3>
            <ol>
              <% const rows = top3BySubject[subject] || []; %>
              <% if (!rows.length) { %>
              <li>Chua co du lieu</li>
              <% } %>
              <% rows.forEach((row) => { %>
              <li><%= row.fullName %> - <%= row.className %> (<%= Number(row.score || 0).toFixed(2) %>)</li>
              <% }); %>
            </ol>
          </article>
          <% } %>
        </div>
      </section>
    </main>
  </body>
</html>
