<!DOCTYPE html>
<html lang="vi">
  <%- include("../shared/head", { title: "Đổi mật khẩu" }) %>
  <body>
    <%- include("../shared/header", { user: null }) %>

    <main class="container auth-wrap">
      <section class="auth-card">
        <h1>Đổi mật khẩu lần đầu</h1>
        <p class="muted">Bạn cần đổi mật khẩu mới trước khi xem bảng điểm.</p>
        <p class="muted" id="autoLogoutNote">Nếu không đổi mật khẩu, hệ thống sẽ tự đăng xuất sau 5 phút.</p>

        <% if (error) { %>
        <p class="alert"><%= error %></p>
        <% } %>

        <form action="/change-password" method="post" class="form-grid">
          <label>
            Mật khẩu mới
            <input type="password" name="newPassword" minlength="6" required />
          </label>

          <label>
            Xác nhận mật khẩu mới
            <input type="password" name="confirmPassword" minlength="6" required />
          </label>

          <button type="submit" class="btn btn-primary">Cập nhật mật khẩu</button>
        </form>
      </section>
    </main>

    <script>
      (function () {
        const logoutKey = "forceChangePasswordLogoutAt";
        const timeoutMinutes = 5;
        const timeoutMs = timeoutMinutes * 60 * 1000;
        const logoutAt = Number(sessionStorage.getItem(logoutKey)) || Date.now() + timeoutMs;
        const note = document.getElementById("autoLogoutNote");

        sessionStorage.setItem(logoutKey, String(logoutAt));

        async function forceLogout() {
          try {
            await fetch("/logout", {
              method: "POST",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
              },
              body: "",
            });
          } catch (error) {
            console.error("Auto logout failed:", error);
          } finally {
            sessionStorage.removeItem(logoutKey);
            window.location.href = "/login";
          }
        }

        function updateCountdown() {
          const remainingMs = logoutAt - Date.now();

          if (remainingMs <= 0) {
            if (note) {
              note.textContent = "Đã hết thời gian chờ. Đang tự đăng xuất...";
            }
            forceLogout();
            return;
          }

          const totalSeconds = Math.ceil(remainingMs / 1000);
          const minutes = Math.floor(totalSeconds / 60);
          const seconds = totalSeconds % 60;

          if (note) {
            note.textContent = `Nếu không đổi mật khẩu, hệ thống sẽ tự đăng xuất sau ${minutes} phút ${String(seconds).padStart(2, "0")} giây.`;
          }
        }

        updateCountdown();
        const timer = setInterval(updateCountdown, 1000);

        window.addEventListener("beforeunload", () => {
          clearInterval(timer);
        });
      })();
    </script>
  </body>
</html>
