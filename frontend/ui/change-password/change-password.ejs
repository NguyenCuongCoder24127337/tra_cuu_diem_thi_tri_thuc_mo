<!DOCTYPE html>
<html lang="vi">
  <%- include("../shared/head", { title: "Đổi mật khẩu" }) %>
  <body>
    <%- include("../shared/header", { user: null }) %>

    <main class="container auth-wrap">
      <section class="auth-card">
        <h1>✅ Đăng nhập thành công</h1>
        <p class="muted">Bạn đã vào được hệ thống. Đây là lần đăng nhập đầu tiên, nên bạn cần đặt mật khẩu mới trước khi xem bảng điểm.</p>
        <p style="background: #fff3cd; border: 1px solid #ffc107; padding: 10px; border-radius: 8px; font-size: 0.95rem; color: #856404;">
          <strong>⏱️ Thời gian chờ:</strong> <span id="autoLogoutNote">Nếu không đổi mật khẩu, hệ thống sẽ tự đăng xuất sau 5 phút.</span>
        </p>

        <div style="background: #e8f5e9; border: 1px solid #81c784; padding: 12px; border-radius: 8px; margin: 12px 0; font-size: 0.95rem; line-height: 1.6;">
          <p><strong>ℹ️ Yêu cầu mật khẩu:</strong></p>
          <ul style="margin: 6px 0; padding-left: 20px;">
            <li>Tối thiểu <strong>6 ký tự</strong></li>
            <li>Ghi nhớ mật khẩu mới (sẽ dùng lần tới)</li>
            <li>Hai ô phải giống nhau</li>
          </ul>
        </div>

        <% if (error) { %>
        <p class="alert" style="background: #ffebee; border: 1px solid #ef5350; color: #c62828; padding: 12px; border-radius: 8px;">
          <strong>❌ Lỗi:</strong><br/>
          <%= error %>
        </p>
        <% } %>

        <form action="/change-password" method="post" class="form-grid" id="changePasswordForm">
          <label>
            Mật khẩu mới
            <div class="password-field">
              <input 
                type="password" 
                id="newPassword"
                name="newPassword" 
                minlength="6" 
                required
                placeholder="Tối thiểu 6 ký tự"
                aria-label="Mật khẩu mới"
              />
              <button
                type="button"
                class="password-toggle"
                id="toggleNewPassword"
                aria-label="Hiện mật khẩu"
                aria-pressed="false"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
                  <path fill="currentColor" d="M12 5c-5.44 0-9.88 3.5-11 7 1.12 3.5 5.56 7 11 7s9.88-3.5 11-7c-1.12-3.5-5.56-7-11-7zm0 12c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                </svg>
              </button>
            </div>
            <small id="passwordHint" style="color: #666; margin-top: 4px; display: block;"></small>
          </label>

          <label>
            Xác nhận mật khẩu mới
            <div class="password-field">
              <input 
                type="password" 
                id="confirmPassword"
                name="confirmPassword" 
                minlength="6" 
                required
                placeholder="Nhập lại mật khẩu mới"
                aria-label="Xác nhận mật khẩu"
              />
              <button
                type="button"
                class="password-toggle"
                id="toggleConfirmPassword"
                aria-label="Hiện mật khẩu"
                aria-pressed="false"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
                  <path fill="currentColor" d="M12 5c-5.44 0-9.88 3.5-11 7 1.12 3.5 5.56 7 11 7s9.88-3.5 11-7c-1.12-3.5-5.56-7-11-7zm0 12c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                </svg>
              </button>
            </div>
            <small id="matchHint" style="color: #666; margin-top: 4px; display: block;"></small>
          </label>

          <button type="submit" class="btn btn-primary" id="submitBtn">
            <span id="submitBtnText">Cập nhật mật khẩu</span>
            <span id="submitBtnLoading" style="display: none;">Đang cập nhật...</span>
          </button>
        </form>
      </section>
    </main>

    <script>
      (function () {
        const newPasswordInput = document.getElementById("newPassword");
        const confirmPasswordInput = document.getElementById("confirmPassword");
        const toggleNewPassword = document.getElementById("toggleNewPassword");
        const toggleConfirmPassword = document.getElementById("toggleConfirmPassword");
        const changePasswordForm = document.getElementById("changePasswordForm");
        const submitBtn = document.getElementById("submitBtn");
        const passwordHint = document.getElementById("passwordHint");
        const matchHint = document.getElementById("matchHint");

        localStorage.setItem("returningUser", "1");

        // Password visibility toggle
        const setupPasswordToggle = (toggleBtn, input) => {
          if (!toggleBtn || !input) return;
          toggleBtn.addEventListener("click", (e) => {
            e.preventDefault();
            const showPassword = input.type === "password";
            input.type = showPassword ? "text" : "password";
            toggleBtn.setAttribute("aria-pressed", showPassword ? "true" : "false");
          });
        };

        setupPasswordToggle(toggleNewPassword, newPasswordInput);
        setupPasswordToggle(toggleConfirmPassword, confirmPasswordInput);

        // Real-time validation
        const updatePasswordHint = () => {
          if (!newPasswordInput) return;
          const pwd = newPasswordInput.value;
          if (pwd.length === 0) {
            passwordHint.textContent = "";
            return;
          }
          if (pwd.length < 6) {
            passwordHint.style.color = "#e74c3c";
            passwordHint.textContent = `❌ Quá ngắn (${pwd.length}/6 ký tự)`;
          } else {
            passwordHint.style.color = "#27ae60";
            passwordHint.textContent = `✓ Hợp lệ (${pwd.length} ký tự)`;
          }
        };

        const updateMatchHint = () => {
          if (!newPasswordInput || !confirmPasswordInput) return;
          const pwd1 = newPasswordInput.value;
          const pwd2 = confirmPasswordInput.value;
          
          if (pwd2.length === 0) {
            matchHint.textContent = "";
            return;
          }

          if (pwd1 === "") {
            matchHint.style.color = "#e67e22";
            matchHint.textContent = "⚠️ Nhập mật khẩu mới trước";
            return;
          }

          if (pwd1 === pwd2) {
            matchHint.style.color = "#27ae60";
            matchHint.textContent = "✓ Mật khẩu khớp nhau";
          } else {
            matchHint.style.color = "#e74c3c";
            matchHint.textContent = "❌ Mật khẩu không khớp";
          }
        };

        if (newPasswordInput) {
          newPasswordInput.addEventListener("input", updatePasswordHint);
        }

        if (confirmPasswordInput) {
          confirmPasswordInput.addEventListener("input", updateMatchHint);
        }

        // Form validation on submit
        if (changePasswordForm) {
          let isSubmitting = false;

          changePasswordForm.addEventListener("submit", (e) => {
            if (isSubmitting) {
              e.preventDefault();
              return;
            }

            const pwd1 = newPasswordInput.value.trim();
            const pwd2 = confirmPasswordInput.value.trim();

            // Validation
            if (!pwd1) {
              e.preventDefault();
              alert("Vui lòng nhập mật khẩu mới");
              newPasswordInput.focus();
              return;
            }

            if (pwd1.length < 6) {
              e.preventDefault();
              alert("Mật khẩu phải tối thiểu 6 ký tự");
              newPasswordInput.focus();
              return;
            }

            if (pwd1 !== pwd2) {
              e.preventDefault();
              alert("Hai ô mật khẩu không giống nhau");
              confirmPasswordInput.focus();
              return;
            }

            // Show loading state
            isSubmitting = true;
            if (submitBtn) {
              submitBtn.disabled = true;
              document.getElementById("submitBtnText").style.display = "none";
              document.getElementById("submitBtnLoading").style.display = "inline";
            }
          });
        }

        // Auto-logout countdown
        const logoutKey = "forceChangePasswordLogoutAt";
        const timeoutMinutes = 5;
        const timeoutMs = timeoutMinutes * 60 * 1000;
        const logoutAt = Number(sessionStorage.getItem(logoutKey)) || Date.now() + timeoutMs;
        const note = document.getElementById("autoLogoutNote");

        sessionStorage.setItem(logoutKey, String(logoutAt));

        async function forceLogout() {
          try {
            await fetch("/logout", {
              method: "POST",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
              },
              body: "",
            });
          } catch (error) {
            console.error("Auto logout failed:", error);
          } finally {
            sessionStorage.removeItem(logoutKey);
            window.location.href = "/login";
          }
        }

        function updateCountdown() {
          const remainingMs = logoutAt - Date.now();

          if (remainingMs <= 0) {
            if (note) {
              note.innerHTML = '<strong>⏹️ Hết thời gian chờ!</strong> Đang chuyển về trang đăng nhập...';
            }
            setTimeout(() => forceLogout(), 2000);
            return;
          }

          const totalSeconds = Math.ceil(remainingMs / 1000);
          const minutes = Math.floor(totalSeconds / 60);
          const seconds = totalSeconds % 60;

          if (note) {
            if (remainingMs < 30000) {
              note.style.color = "#e74c3c";
              note.innerHTML = `<strong>⚠️ Chỉ còn ${minutes}:${String(seconds).padStart(2, "0")}</strong> - Vui lòng hoàn thành!`;
            } else {
              note.textContent = `Nếu không đổi mật khẩu, hệ thống sẽ tự đăng xuất sau ${minutes} phút ${String(seconds).padStart(2, "0")} giây.`;
            }
          }
        }

        updateCountdown();
        const timer = setInterval(updateCountdown, 1000);

        window.addEventListener("beforeunload", () => {
          clearInterval(timer);
        });
      })();
    </script>
  </body>
</html>
