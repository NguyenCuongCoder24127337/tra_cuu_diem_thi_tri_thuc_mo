<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href="/">
      <img src="/logo_web.jpg" alt="Logo trường" class="brand-logo" />
      <span class="brand-text">Tra Cứu Điểm Thi</span>
    </a>

    <nav class="menu">
      <% if (user) { %>
      <a href="/dashboard">Bảng điểm</a>
      <form action="/logout" method="post">
        <button type="submit" class="btn btn-outline">Đăng xuất</button>
      </form>
      <% } else { %>
      <% if (typeof homepage !== "undefined" && homepage) { %>
      <span class="header-blessing">Hiểu mình - Chọn Nghề - Sáng tương lai</span>
      <% } else { %>
      <% if (!(typeof hideLoginButton !== "undefined" && hideLoginButton)) { %>
      <a href="/login" class="btn btn-primary">Đăng nhập</a>
      <% } %>
      <% } %>
      <% } %>
    </nav>
  </div>
</header>
