<div class="feedback-modal" id="feedbackModal" aria-hidden="true">
  <div class="feedback-overlay" id="feedbackOverlay"></div>
  <section class="feedback-card" role="dialog" aria-modal="true" aria-labelledby="feedbackTitle">
    <button class="feedback-close" id="feedbackClose" aria-label="Đóng">&times;</button>
    <h2 id="feedbackTitle">Góp ý cải thiện</h2>
    <p class="feedback-subtitle">Chia sẻ ý kiến của bạn để giúp chúng tôi phát triển web tốt hơn.</p>

    <form class="feedback-form" id="feedbackForm">
      <label>
        <span>Họ tên <span class="required">*</span></span>
        <input type="text" name="fullName" required />
      </label>

      <label>
        <span>Email</span>
        <input type="email" name="email" />
      </label>

      <label>
        <span>Số điện thoại</span>
        <input type="tel" name="phone" />
      </label>

      <label>
        <span>Tiêu đề góp ý <span class="required">*</span></span>
        <input type="text" name="title" placeholder="Ví dụ: Giao diện khó sử dụng trên mobile" required />
      </label>

      <label>
        <span>Nội dung chi tiết <span class="required">*</span></span>
        <textarea name="message" rows="5" placeholder="Mô tả chi tiết góp ý của bạn..." required></textarea>
      </label>

      <div id="feedbackStatus" class="feedback-status"></div>

      <button type="submit" class="btn btn-primary feedback-submit">Gửi góp ý</button>
    </form>
  </section>
</div>

<button class="feedback-btn" id="feedbackBtn" aria-label="Gửi góp ý">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
</button>

<style>
  .feedback-btn {
    position: fixed;
    bottom: 24px;
    left: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #b84e1f, #d76b37);
    color: #fff;
    border: none;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(79, 42, 19, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    z-index: 40;
  }

  .feedback-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(79, 42, 19, 0.4);
  }

  .feedback-btn:active {
    transform: translateY(0);
  }

  .feedback-modal {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 16px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .feedback-modal.open {
    display: flex;
    opacity: 1;
    pointer-events: auto;
  }

  .feedback-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .feedback-card {
    position: relative;
    background: #fffdfa;
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 24px 48px rgba(42, 23, 11, 0.2);
    max-width: 580px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    animation: feedbackScale 0.3s ease forwards;
  }

  @keyframes feedbackScale {
    from {
      transform: scale(0.92);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .feedback-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    font-size: 24px;
    color: #645243;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .feedback-close:hover {
    color: #1f1812;
  }

  .feedback-card h2 {
    margin-top: 0;
    margin-bottom: 8px;
    font-size: 1.6rem;
    color: #1f1812;
  }

  .feedback-subtitle {
    margin-bottom: 20px;
    color: #645243;
    font-size: 0.98rem;
    line-height: 1.5;
  }

  .feedback-form {
    display: grid;
    gap: 14px;
  }

  .feedback-form label {
    display: grid;
    gap: 6px;
  }

  .feedback-form label span {
    font-size: 0.98rem;
    font-weight: 600;
    color: #1f1812;
  }

  .required {
    color: #ca3a1a;
  }

  .feedback-form input,
  .feedback-form textarea {
    padding: 10px 12px;
    border: 1px solid #e6d6c7;
    border-radius: 12px;
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 1rem;
    color: #1f1812;
    transition: border-color 0.2s ease;
  }

  .feedback-form input:focus,
  .feedback-form textarea:focus {
    outline: none;
    border-color: #b84e1f;
    box-shadow: 0 0 0 3px rgba(184, 78, 31, 0.1);
  }

  .feedback-form textarea {
    resize: vertical;
  }

  .feedback-status {
    padding: 12px;
    border-radius: 12px;
    font-size: 0.95rem;
    text-align: center;
    display: none;
  }

  .feedback-status.success {
    display: block;
    background: #e6f5e1;
    color: #1e5620;
    border: 1px solid #b8dbb3;
  }

  .feedback-status.error {
    display: block;
    background: #fae6e6;
    color: #8a3310;
    border: 1px solid #efbc9d;
  }

  .feedback-submit {
    width: 100%;
    margin-top: 8px;
  }

  .feedback-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  @media (max-width: 740px) {
    .feedback-card {
      border-radius: 16px;
      padding: 18px 14px;
    }

    .feedback-card h2 {
      font-size: 1.4rem;
    }

    .feedback-btn {
      bottom: 16px;
      left: 16px;
      width: 48px;
      height: 48px;
    }
  }
</style>

<script>
  (function () {
    const btn = document.getElementById("feedbackBtn");
    const modal = document.getElementById("feedbackModal");
    const overlay = document.getElementById("feedbackOverlay");
    const closeBtn = document.getElementById("feedbackClose");
    const form = document.getElementById("feedbackForm");
    const statusEl = document.getElementById("feedbackStatus");

    if (!btn || !modal || !form) return;

    btn.addEventListener("click", function () {
      modal.classList.add("open");
      modal.setAttribute("aria-hidden", "false");
    });

    function closeModal() {
      modal.classList.remove("open");
      modal.setAttribute("aria-hidden", "true");
      form.reset();
      statusEl.textContent = "";
      statusEl.className = "feedback-status";
    }

    closeBtn.addEventListener("click", closeModal);
    overlay.addEventListener("click", closeModal);

    form.addEventListener("submit", async function (e) {
      e.preventDefault();

      const submitBtn = form.querySelector(".feedback-submit");
      const formData = new FormData(form);
      const data = {
        fullName: formData.get("fullName"),
        email: formData.get("email"),
        phone: formData.get("phone"),
        title: formData.get("title"),
        message: formData.get("message"),
      };

      submitBtn.disabled = true;
      statusEl.textContent = "Đang gửi...";
      statusEl.className = "feedback-status";

      try {
        const response = await fetch("/api/feedback/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (result.success) {
          statusEl.textContent = "✓ Cảm ơn góp ý của bạn. Chúng tôi sẽ xem xét và cải thiện.";
          statusEl.className = "feedback-status success";
          form.reset();
          setTimeout(() => {
            closeModal();
          }, 2000);
        } else {
          statusEl.textContent = "✗ " + (result.error || "Có lỗi xảy ra");
          statusEl.className = "feedback-status error";
        }
      } catch (error) {
        statusEl.textContent = "✗ Không thể kết nối. Vui lòng thử lại.";
        statusEl.className = "feedback-status error";
      } finally {
        submitBtn.disabled = false;
      }
    });
  })();
</script>

