<!DOCTYPE html>
<html lang="vi">
  <%- include("../shared/head", { title: "Trang chủ - Tra cứu điểm thi" }) %>
  <body>
    <%- include("../shared/header", { user, homepage: true }) %>

    <main>
      <section class="hero">
        <div class="container hero-content">
          <div class="hero-copy hero-single">
            <h1>Tra cứu điểm thi</h1>
            <p class="hero-lead">
              Đăng nhập để xem điểm thi của bạn
            </p>
            <div class="hero-buttons">
              <a href="/login" class="btn btn-primary btn-large" id="loginBtn">Đăng nhập</a>
              <button type="button" class="btn btn-outline btn-large" id="helpBtn" aria-label="Mở tra cứu username">Tra cứu username</button>
            </div>
          </div>
        </div>
      </section>

      <section class="lookup-section" id="lookupSection" aria-label="Tra cứu tài khoản theo tên" style="display: none;">
        <div class="container lookup-card">
          <button type="button" class="lookup-close-btn" id="closeLookupBtn" aria-label="Đóng tìm kiếm">✕</button>
          <h2>🔍 Tìm tài khoản của bạn</h2>
          <p>
            Đăng nhập lần đầu: vui lòng nhập đúng họ và tên để tìm username.
          </p>

          <div style="background: #f0f7ff; border: 1px solid #90caf9; padding: 10px; border-radius: 8px; margin: 10px 0; font-size: 0.9rem;">
            <strong>💡 Mẹo tìm kiếm:</strong>
            <ul style="margin: 6px 0; padding-left: 16px;">
              <li>Bước 1 (bắt buộc): Nhập <strong>họ và tên đầy đủ</strong> (vd: Nguyễn Văn A)</li>
            </ul>
          </div>

          <form id="lookupForm" class="lookup-form" autocomplete="off">
            <label for="lookupInput">Nhập họ và tên đầy đủ</label>
            <div class="lookup-input-row">
              <input
                type="text"
                id="lookupInput"
                name="lookupName"
                placeholder="Ví dụ: Nguyễn Văn A"
                minlength="1"
                maxlength="50"
                required
              />
              <button type="submit" class="btn btn-primary" id="lookupSubmitBtn">
                <span id="lookupBtnText">Tra cứu</span>
                <span id="lookupBtnLoading" style="display: none;">Đang tìm...</span>
              </button>
            </div>
          </form>

          <p id="lookupStatus" class="lookup-status" aria-live="polite" aria-atomic="true"></p>
          <div id="lookupResults" class="lookup-results" aria-live="polite" aria-atomic="true"></div>
        </div>
      </section>

    </main>

    <div class="popup-overlay" id="homeNoticePopup" aria-hidden="true">
      <section class="popup-card" role="dialog" aria-modal="true" aria-labelledby="homeNoticeTitle">
        <button type="button" class="popup-x-btn" id="closeHomeNoticeBtnTop" aria-label="Đóng thông báo">×</button>
        <h2 id="homeNoticeTitle">Tra cứu trước khi đăng nhập</h2>
        <div id="homeNoticeBody" class="popup-content">
          <p><strong>Bạn là người đăng nhập lần đầu.</strong></p>
          <p>Hãy bấm <strong>Tra cứu username</strong>, nhập <strong>đúng họ và tên đầy đủ</strong>, rồi click đúng username để hệ thống tự điền username và mật khẩu ban đầu.</p>
        </div>
        <div class="popup-buttons">
          <button type="button" class="btn btn-primary" id="goLookupBtn">Đi tra cứu</button>
          <button type="button" class="btn btn-outline" id="dismissHomeNoticeBtn">Đóng</button>
        </div>
      </section>
    </div>

    <%- include("../shared/contact-buttons") %>

    <script>
      (function () {
        document.body.classList.add("homepage");

        const loginBtn = document.getElementById("loginBtn");
        const helpBtn = document.getElementById("helpBtn");
        const lookupSection = document.getElementById("lookupSection");
        const closeLookupBtn = document.getElementById("closeLookupBtn");
        const lookupForm = document.getElementById("lookupForm");
        const lookupInput = document.getElementById("lookupInput");
        const lookupStatus = document.getElementById("lookupStatus");
        const lookupResults = document.getElementById("lookupResults");
        const homeNoticePopup = document.getElementById("homeNoticePopup");
        const homeNoticeTitle = document.getElementById("homeNoticeTitle");
        const homeNoticeBody = document.getElementById("homeNoticeBody");
        const goLookupBtn = document.getElementById("goLookupBtn");
        const dismissHomeNoticeBtn = document.getElementById("dismissHomeNoticeBtn");
        const closeHomeNoticeBtnTop = document.getElementById("closeHomeNoticeBtnTop");

        const lookupCompletedKey = "lookupCompleted";
        const returningUserKey = "returningUser";
        const autoLoginAccountKey = "autoLoginAccount";
        const autoLoginPasswordKey = "autoLoginPassword";
        const openLookupFromQuery = new URLSearchParams(window.location.search).get("lookup") === "1";
        const hasLookupCompleted = () => localStorage.getItem(lookupCompletedKey) === "1";
        const isReturningUser = () => localStorage.getItem(returningUserKey) === "1";

        function openHomeNoticePopup({ title, body, primaryText, secondaryText, primaryAction, secondaryAction }) {
          if (!homeNoticePopup) return;
          if (homeNoticeTitle && title) {
            homeNoticeTitle.textContent = title;
          }
          if (homeNoticeBody && body) {
            homeNoticeBody.innerHTML = body;
          }
          if (goLookupBtn && primaryText) {
            goLookupBtn.textContent = primaryText;
            goLookupBtn.onclick = primaryAction || null;
          }
          if (dismissHomeNoticeBtn) {
            dismissHomeNoticeBtn.textContent = secondaryText || "Đóng";
            dismissHomeNoticeBtn.onclick = secondaryAction || null;
            dismissHomeNoticeBtn.style.display = secondaryText ? "inline-flex" : "none";
          }
          homeNoticePopup.classList.add("open");
          homeNoticePopup.setAttribute("aria-hidden", "false");
        }

        function closeHomeNoticePopup() {
          if (!homeNoticePopup) return;
          homeNoticePopup.classList.remove("open");
          homeNoticePopup.setAttribute("aria-hidden", "true");
        }

        function showLookupSection() {
          if (!lookupSection) return;
          lookupSection.style.display = "block";
          // Scroll to lookup section
          lookupSection.scrollIntoView({ behavior: "smooth" });
          lookupInput.focus();
        }

        function hideLookupSection() {
          if (!lookupSection) return;
          lookupSection.style.display = "none";
        }

        if (openLookupFromQuery) {
          window.setTimeout(showLookupSection, 80);
        }

        // Nút trên hero mở phần tra cứu
        if (helpBtn) {
          helpBtn.addEventListener("click", showLookupSection);
        }

        if (loginBtn) {
          loginBtn.addEventListener("click", function (event) {
            if (isReturningUser()) {
              return;
            }

            event.preventDefault();
            openHomeNoticePopup({
              title: "Tra cứu trước khi vào web",
              body: `
                <p><strong>Bạn là người đăng nhập lần đầu.</strong></p>
                <p>Trước khi vào web, hãy tra cứu username của bạn ở phần tìm kiếm bên dưới.</p>
                <p>Hãy nhập <strong>đúng họ và tên đầy đủ</strong> để tìm trước.</p>
                <p>Nếu chưa thấy, hãy thử <strong>chữ cái đầu</strong> hoặc tên gần đúng vì dữ liệu có thể bị sai ký tự khi nhập.</p>
              `,
              primaryText: "Đi tra cứu",
              secondaryText: "",
              primaryAction: function () {
                closeHomeNoticePopup();
                showLookupSection();
              },
              secondaryAction: null,
            });
          });
        }

        if (closeHomeNoticeBtnTop) {
          closeHomeNoticeBtnTop.addEventListener("click", closeHomeNoticePopup);
        }

        if (goLookupBtn) {
          goLookupBtn.addEventListener("click", function () {
            closeHomeNoticePopup();
            showLookupSection();
          });
        }

        if (dismissHomeNoticeBtn) {
          dismissHomeNoticeBtn.addEventListener("click", function () {
            closeHomeNoticePopup();
          });
        }

        if (homeNoticePopup) {
          homeNoticePopup.addEventListener("click", function (event) {
            if (event.target === homeNoticePopup) {
              closeHomeNoticePopup();
            }
          });
        }

        // Đóng section tra cứu
        if (closeLookupBtn) {
          closeLookupBtn.addEventListener("click", function () {
            hideLookupSection();
            lookupForm.reset();
            lookupStatus.textContent = "";
            lookupResults.innerHTML = "";
          });
        }

        function escapeHtml(value) {
          return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
        }

        function renderLookupResults(items) {
          if (!lookupResults) return;

          if (!Array.isArray(items) || items.length === 0) {
            lookupResults.innerHTML = "";
            if (lookupStatus) {
                lookupStatus.innerHTML = `
                  <strong>Chưa tìm thấy username theo tên này.</strong><br/>
                  <small>• Có thể bạn nhập nhầm tên, hoặc hệ thống lưu tên bị sai ký tự, ví dụ họ <strong>Phạm</strong> bị lưu thành <strong>Phan</strong>.</small><br/>
                  <small>• Hãy nhập chữ cái đầu tiên của tên để tra cứu.</small><br/>
                  <small>• Nếu bạn tên <strong>Phạm Thị Nhi</strong> nhưng lại thấy <strong>Phan Thị Nhi</strong>, rất có thể đó là username đúng của bạn, hãy click để đăng nhập.</small><br/>
                  <small>• Nếu vẫn không thấy, liên hệ Zalo (nhấn nút <strong>3 chấm</strong> ở góc phải) để kiểm tra dữ liệu.</small>
                `;
            }
            return;
          }

          const rows = items
            .map(
              (item) =>
                `<article class="lookup-item" role="button" tabindex="0" data-username="${escapeHtml(item.username)}" data-fullname="${escapeHtml(item.fullName)}" data-must-change-password="${item.mustChangePassword ? "true" : "false"}">
                  <p class="lookup-fullname">${escapeHtml(item.fullName)}</p>
                  <p class="lookup-username">Username: <strong>${escapeHtml(item.username)}</strong></p>
                  <p class="lookup-hint">👆 Click để kiểm tra đăng nhập</p>
                </article>`
            )
            .join("");

          lookupResults.innerHTML = rows;

          // Gán sự kiện click cho từng item
          document.querySelectorAll(".lookup-item").forEach((item) => {
            const clickHandler = function () {
              const username = this.getAttribute("data-username");
              const fullname = this.getAttribute("data-fullname");
              const mustChangePassword = this.getAttribute("data-must-change-password") === "true";

              if (username) {
                if (mustChangePassword) {
                  localStorage.setItem(lookupCompletedKey, "1");
                  sessionStorage.setItem(autoLoginAccountKey, username);
                  sessionStorage.setItem(autoLoginPasswordKey, username);
                  window.location.href = "/login?autofill=1";
                  return;
                }

                openHomeNoticePopup({
                  title: "Tài khoản đã đổi mật khẩu",
                  body: `
                    <p><strong>Tài khoản ${escapeHtml(fullname || username)} đã đổi mật khẩu.</strong></p>
                    <p>Không thể tự đăng nhập bằng username cũ.</p>
                    <p>Có thể đã có người khác đổi mật khẩu account của bạn.</p>
                    <p>Nếu đây là tài khoản của bạn, hãy liên hệ Zalo (nhấn nút <strong>3 chấm</strong> ở góc phải) để lấy lại hoặc xác nhận mật khẩu mới.</p>
                    <p>Nếu bạn nghĩ dữ liệu bị sai, hãy nhập lại chữ cái đầu hoặc tên gần đúng để tra cứu đúng username.</p>
                  `,
                  primaryText: "Tra cứu lại",
                  secondaryText: "Đóng",
                  primaryAction: function () {
                    closeHomeNoticePopup();
                    if (lookupForm) {
                      lookupForm.reset();
                    }
                    if (lookupStatus) {
                      lookupStatus.textContent = "";
                    }
                    if (lookupResults) {
                      lookupResults.innerHTML = "";
                    }
                    showLookupSection();
                  },
                  secondaryAction: closeHomeNoticePopup,
                });
              }
            };

            item.addEventListener("click", clickHandler);

            // Hỗ trợ bàn phím (Enter, Space)
            item.addEventListener("keydown", function (e) {
              if (e.key === "Enter" || e.key === " ") {
                e.preventDefault();
                clickHandler.call(this);
              }
            });
          });

          if (lookupStatus) {
            const count = items.length;
            if (count === 1) {
              lookupStatus.innerHTML = `<strong>✓ Tìm thấy ${count} kết quả</strong><br/><small>Click vào tài khoản để kiểm tra đăng nhập</small>`;
            } else {
              lookupStatus.innerHTML = `<strong>✓ Tìm thấy ${count} kết quả</strong><br/><small>Chọn đúng tài khoản của bạn rồi click</small>`;
            }
          }
        }

        if (lookupForm && lookupInput && lookupResults) {
          let isSearching = false;
          let hasTriedFullNameLookup = false;

          function looksLikeFullName(value) {
            const parts = String(value || "")
              .trim()
              .split(/\s+/)
              .filter(Boolean);
            return parts.length >= 2;
          }

          lookupForm.addEventListener("submit", async function (event) {
            event.preventDefault();

            if (isSearching) return;

            const keyword = lookupInput.value.trim();
            if (!keyword) {
              lookupInput.focus();
              lookupStatus.textContent = "⚠️ Vui lòng nhập họ và tên để tra cứu";
              return;
            }

            if (!hasTriedFullNameLookup && !looksLikeFullName(keyword)) {
              lookupInput.focus();
              lookupStatus.innerHTML = "⚠️ Lần đầu bạn cần nhập <strong>đúng họ và tên đầy đủ</strong> (vd: Nguyễn Văn A). Nếu chưa thấy kết quả, lần sau bạn có thể thử chữ cái đầu.";
              return;
            }

            if (looksLikeFullName(keyword)) {
              hasTriedFullNameLookup = true;
            }

            isSearching = true;
            const submitBtn = document.getElementById("lookupSubmitBtn");
            if (submitBtn) {
              submitBtn.disabled = true;
              document.getElementById("lookupBtnText").style.display = "none";
              document.getElementById("lookupBtnLoading").style.display = "inline";
            }

            if (lookupStatus) {
              lookupStatus.textContent = "🔍 Đang tra cứu...";
            }

            try {
              const response = await fetch(`/api/home/find-account?q=${encodeURIComponent(keyword)}`, {
                signal: AbortSignal.timeout(5000), // 5 second timeout
              });
              
              const payload = await response.json().catch(() => ({}));

              if (!response.ok) {
                lookupResults.innerHTML = "";
                if (lookupStatus) {
                  if (response.status === 500) {
                    lookupStatus.textContent = "❌ Lỗi hệ thống. Vui lòng thử lại sau.";
                  } else {
                    lookupStatus.textContent = payload.error || "❌ Không thể tra cứu lúc này. Vui lòng thử lại.";
                  }
                }
                isSearching = false;
                if (submitBtn) {
                  submitBtn.disabled = false;
                  document.getElementById("lookupBtnText").style.display = "inline";
                  document.getElementById("lookupBtnLoading").style.display = "none";
                }
                return;
              }

              renderLookupResults(payload.items || []);
            } catch (error) {
              console.error("Lookup username error:", error);
              lookupResults.innerHTML = "";
              if (lookupStatus) {
                if (error.name === "AbortError") {
                  lookupStatus.textContent = "❌ Tìm kiếm quá lâu. Vui lòng thử lại.";
                } else if (error instanceof TypeError) {
                  lookupStatus.textContent = "❌ Lỗi kết nối. Kiểm tra internet và thử lại.";
                } else {
                  lookupStatus.textContent = "❌ Có lỗi không xác định. Vui lòng liên hệ hỗ trợ.";
                }
              }
            } finally {
              isSearching = false;
              if (submitBtn) {
                submitBtn.disabled = false;
                document.getElementById("lookupBtnText").style.display = "inline";
                document.getElementById("lookupBtnLoading").style.display = "none";
              }
            }
          });
        }

      })();
    </script>
  </body>
</html>
