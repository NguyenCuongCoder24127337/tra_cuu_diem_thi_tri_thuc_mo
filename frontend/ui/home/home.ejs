<!DOCTYPE html>
<html lang="vi">
  <%- include("../shared/head", { title: "Trang chủ - Tra cứu điểm thi" }) %>
  <body>
    <%- include("../shared/header", { user, homepage: true }) %>

    <main>
      <section class="hero">
        <div class="container hero-content">
          <div class="hero-copy hero-single">
            <p class="hero-eyebrow">Tra cứu điểm thi nhanh và rõ ràng</p>
            <h1>Hệ thống tra cứu điểm thi học sinh</h1>
            <p class="hero-lead">
              Nhập đúng họ và tên để kiểm tra chính xác, hoặc chỉ cần nhập tên để tìm nhanh username.
              Account đã được trung tâm tạo sẵn, học sinh chỉ cần đăng nhập.
            </p>
            <a href="/login?guide=1" class="btn btn-primary btn-large" id="loginBtn">Vào trang đăng nhập</a>
          </div>
        </div>
      </section>

      <section class="lookup-section" aria-label="Tra cứu username theo tên">
        <div class="container lookup-card">
          <p class="lookup-label">Tra cứu username trước khi đăng nhập</p>
          <h2>Tìm username nhanh theo tên</h2>
          <p>
            Nếu chưa đăng nhập được, hãy tra cứu username trước. Có thể dữ liệu đang bị gõ lệch dấu hoặc viết tắt so với tên của bạn
            (ví dụ: Phạm thành Phan, Nguyễn Văn A thành Nguyễn A).
          </p>
          <p>
            Muốn kiểm tra đúng thông tin của chính bạn, hãy nhập <strong>họ và tên đầy đủ</strong> để hệ thống trả về đúng kết quả của người đó.
          </p>
          <p>
            Nếu không tìm thấy, có thể dữ liệu đang bị lưu sai hoặc tên đang bị ghi lệch. Lúc đó bạn chỉ cần nhập <strong>tên</strong>
            (ví dụ: Cường) để hệ thống tìm nhanh username gần đúng.
          </p>
          <p class="lookup-tip">
            Khuyến khích dùng tính năng này trước khi vào trang đăng nhập để chắc chắn account của bạn đã tồn tại.
          </p>

          <form id="lookupForm" class="lookup-form" autocomplete="off">
            <label for="lookupInput">Nhập họ và tên đầy đủ để kiểm tra, hoặc nhập tên để tìm username</label>
            <div class="lookup-input-row">
              <input
                type="text"
                id="lookupInput"
                name="lookupName"
                placeholder="Ví dụ: Cường"
                minlength="2"
                required
              />
              <button type="submit" class="btn btn-primary">Tra cứu</button>
            </div>
          </form>

          <p id="lookupStatus" class="lookup-status" aria-live="polite"></p>
          <div id="lookupResults" class="lookup-results" aria-live="polite"></div>
        </div>
      </section>

      <section class="countdown-section" aria-label="Đếm ngược đến kỳ thi đại học">
        <div class="container countdown-card">
          <p class="countdown-kicker">Đếm ngược đến kỳ thi đại học</p>
          <h2>11 / 6 / 2026</h2>
          <p class="countdown-label">Còn lại</p>
          <div class="countdown-grid" id="countdownGrid">
            <div><strong id="daysLeft">0</strong><span>Ngày</span></div>
            <div><strong id="hoursLeft">0</strong><span>Giờ</span></div>
            <div><strong id="minutesLeft">0</strong><span>Phút</span></div>
            <div><strong id="secondsLeft">0</strong><span>Giây</span></div>
          </div>
        </div>
      </section>
    </main>

    <div class="popup-overlay" id="homeLoginGuidePopup" aria-hidden="true">
      <section class="popup-card" role="dialog" aria-modal="true" aria-labelledby="homePopupTitle">
        <button type="button" class="popup-x-btn" id="closeHomePopupTop" aria-label="Đóng popup">×</button>
        <h2 id="homePopupTitle">Lưu ý trước khi đăng nhập</h2>
        <ol>
          <li><strong>Tuyệt đối không tự tạo account mới</strong>. Tự tạo account sẽ không xem được điểm.</li>
          <li>Account của học sinh đã được trung tâm tạo sẵn, bạn chỉ cần đăng nhập.</li>
          <li>Ví dụ: Nguyễn Văn A thì username là NguyenVanA, mật khẩu lần đầu cũng là NguyenVanA.</li>
          <li>Nếu nhập sai hoặc không vào được, hãy tra cứu username theo tên ở ô bên dưới.</li>
          <li>Nếu đã tra cứu mà vẫn không đăng nhập được, hãy liên hệ Zalo hỗ trợ.</li>
          <li>Nếu muốn góp ý phát triển web, hãy bấm nút Góp ý phát triển web.</li>
        </ol>
        <button type="button" class="btn btn-primary" id="closeHomePopup">Tôi đã hiểu</button>
      </section>
    </div>

    <%- include("../shared/contact-buttons") %>

    <script>
      (function () {
        document.body.classList.add("homepage");

        const homePopup = document.getElementById("homeLoginGuidePopup");
        const closeHomePopup = document.getElementById("closeHomePopup");
        const closeHomePopupTop = document.getElementById("closeHomePopupTop");
        const lookupForm = document.getElementById("lookupForm");
        const lookupInput = document.getElementById("lookupInput");
        const lookupStatus = document.getElementById("lookupStatus");
        const lookupResults = document.getElementById("lookupResults");

        function openHomePopup() {
          if (!homePopup) return;
          homePopup.classList.add("open");
          homePopup.setAttribute("aria-hidden", "false");
        }

        function hideHomePopup() {
          if (!homePopup) return;
          homePopup.classList.remove("open");
          homePopup.setAttribute("aria-hidden", "true");
        }

        openHomePopup();

        if (closeHomePopup) {
          closeHomePopup.addEventListener("click", hideHomePopup);
        }

        if (closeHomePopupTop) {
          closeHomePopupTop.addEventListener("click", hideHomePopup);
        }

        if (homePopup) {
          homePopup.addEventListener("click", function (event) {
            if (event.target === homePopup) {
              hideHomePopup();
            }
          });
        }

        function escapeHtml(value) {
          return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
        }

        function renderLookupResults(items) {
          if (!lookupResults) return;

          if (!Array.isArray(items) || items.length === 0) {
            lookupResults.innerHTML = "";
            if (lookupStatus) {
              lookupStatus.textContent = "Chưa thấy kết quả phù hợp. Bạn thử tên gần đúng khác nhé.";
            }
            return;
          }

          const rows = items
            .map(
              (item) =>
                `<article class="lookup-item"><p class="lookup-fullname">${escapeHtml(item.fullName)}</p><p class="lookup-username">Username: <strong>${escapeHtml(item.username)}</strong></p></article>`
            )
            .join("");

          lookupResults.innerHTML = rows;

          if (lookupStatus) {
            const isExact = items.every((item) => item.matchType === "exact");
            lookupStatus.textContent = isExact
              ? `Đã tìm thấy đúng thông tin theo họ và tên (${items.length} kết quả).`
              : `Đã tìm thấy ${items.length} kết quả phù hợp.`;
          }
        }

        if (lookupForm && lookupInput && lookupResults) {
          lookupForm.addEventListener("submit", async function (event) {
            event.preventDefault();

            const keyword = lookupInput.value.trim();
            if (!keyword) {
              return;
            }

            if (lookupStatus) {
              lookupStatus.textContent = "Đang tra cứu...";
            }

            try {
              const response = await fetch(`/api/home/find-account?q=${encodeURIComponent(keyword)}`);
              const payload = await response.json().catch(() => ({}));

              if (!response.ok) {
                lookupResults.innerHTML = "";
                if (lookupStatus) {
                  lookupStatus.textContent = payload.error || "Không thể tra cứu lúc này.";
                }
                return;
              }

              renderLookupResults(payload.items || []);
            } catch (error) {
              console.error("Lookup username error:", error);
              lookupResults.innerHTML = "";
              if (lookupStatus) {
                lookupStatus.textContent = "Có lỗi kết nối. Vui lòng thử lại.";
              }
            }
          });
        }

        const targetDate = new Date(2026, 5, 11, 0, 0, 0).getTime();
        const daysEl = document.getElementById("daysLeft");
        const hoursEl = document.getElementById("hoursLeft");
        const minutesEl = document.getElementById("minutesLeft");
        const secondsEl = document.getElementById("secondsLeft");

        if (daysEl && hoursEl && minutesEl && secondsEl) {
          function pad(value) {
            return String(value).padStart(2, "0");
          }

          function updateCountdown() {
            const now = Date.now();
            const diff = Math.max(0, targetDate - now);

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const minutes = Math.floor((diff / (1000 * 60)) % 60);
            const seconds = Math.floor((diff / 1000) % 60);

            daysEl.textContent = days;
            hoursEl.textContent = pad(hours);
            minutesEl.textContent = pad(minutes);
            secondsEl.textContent = pad(seconds);
          }

          updateCountdown();
          setInterval(updateCountdown, 1000);
        }
      })();
    </script>
  </body>
</html>
